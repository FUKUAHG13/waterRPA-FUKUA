    datas=[],
    hiddenimports=[],
    hookspath=['hooks_lite'],
    hooksconfig={},
    runtime_hooks=[],
    excludes=[
        'cv2',
        'numpy',
        'numpy_distutils',
        'psutil',
        'tkinter',
        '_tkinter',
        'PIL.AvifImagePlugin',
        'PIL.FpxImagePlugin',
        'PIL.ImageTk',
        'PIL.MicImagePlugin',
        'PIL.PdfImagePlugin',
        'PIL.TiffImagePlugin',
        'PIL.WebPImagePlugin',
