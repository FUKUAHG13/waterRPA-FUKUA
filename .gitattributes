# Let Git detect text files, then keep source line endings predictable.
* text=auto

*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.svg text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Never attempt text conversion or textual diffs for generated binaries.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.dll binary
*.exe binary
*.zip binary
*.pyd binary
*.lib binary
*.obj binary
